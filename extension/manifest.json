{
  "manifest_version": 3,
  "name": "Reader Bot",
  "version": "1.0",
  "description": "Зберегти статтю у PDF, Markdown, HTML або EPUB",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Reader Bot"
  }
}
