BOT_TOKEN=your_bot_token_here

# Telegram id адміністраторів через кому (команди /admin, /users, /stats, /failed).
# Спільний для api та bot. Дізнатись свій id можна через @userinfobot.
# ADMIN_IDS=123456789,987654321

# Шлях до SQLite бази (за замовчуванням /app/data/articles.db)
# DB_PATH=/app/data/articles.db

# Для підключення домену через nginx-proxy (необов'язково)
# API_DOMAIN=reader.your-domain.com

# Для Cloudflare Tunnel (необов'язково, запуск: docker compose --profile tunnel up)
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Капч-солвер у сервісі renderer (необов'язково, ВИМКНЕНО за замовчуванням).
# ⚠️ Платний зовнішній сервіс (людська ферма), часто порушує ToS сайту.
# Вмикається ТІЛЬКИ коли задані обидві змінні.
# CAPTCHA_PROVIDER=2captcha
# CAPTCHA_API_KEY=your_2captcha_key

# --- Браузерний фолбек (вибір бекенду) ------------------------------------
# legacy        — локальний сервіс `renderer` (Playwright/camoufox), за замовчуванням.
# browser_agent — зовнішній сервіс browser-agent (`generic/get_page`).
#                 Якщо він недосяжний — auto-fallback на локальний `renderer`.
# EXTRACT_BACKEND=legacy

# --- browser-agent (потрібно тільки коли EXTRACT_BACKEND=browser_agent) ---
# URL агента (HTTPS публічний або internal). Порожній — вимикає browser_agent режим.
# BROWSER_AGENT_URL=https://browser-agent.example.com
# BROWSER_AGENT_API_KEY=your_browser_agent_key

# Публічний URL цього api, на який BA постить callback (cloudflared/nginx).
# Без нього BA лишається без callback → доводимо poll-ом.
# PARSER_CALLBACK_BASE_URL=https://reader.your-domain.com
# Bearer-токен у заголовку callback'у (захист endpoint'у /internal/parser-callback).
# PARSER_CALLBACK_SECRET=random-long-secret

# Очікування результату на боці api (сек). Має бути < таймауту бота 130с.
# PARSER_WAIT_TIMEOUT_SEC=110
# Інтервал polling'у GET /api/tasks/:id як fallback на випадок втрати callback'у.
# PARSER_POLL_INTERVAL_SEC=2
# Обмеження розміру html у відповіді BA.
# PARSER_MAX_BYTES=500000
# Жорстко зафіксувати тир BA (curl|playwright|browser). Без нього BA вибирає сам.
# PARSER_FORCE_TIER=playwright
