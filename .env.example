BOT_TOKEN=your_bot_token_here

# Telegram id адміністраторів через кому (команди /admin, /users, /stats, /failed).
# Спільний для api та bot. Дізнатись свій id можна через @userinfobot.
# ADMIN_IDS=123456789,987654321

# Шлях до SQLite бази (за замовчуванням /app/data/articles.db)
# DB_PATH=/app/data/articles.db

# Для підключення домену через nginx-proxy (необов'язково)
# API_DOMAIN=reader.your-domain.com

# Для Cloudflare Tunnel (необов'язково, запуск: docker compose --profile tunnel up)
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Капч-солвер у сервісі renderer (необов'язково, ВИМКНЕНО за замовчуванням).
# ⚠️ Платний зовнішній сервіс (людська ферма), часто порушує ToS сайту.
# Вмикається ТІЛЬКИ коли задані обидві змінні.
# CAPTCHA_PROVIDER=2captcha
# CAPTCHA_API_KEY=your_2captcha_key
